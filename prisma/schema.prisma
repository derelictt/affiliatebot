generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String     @id @default(cuid())
  sourceUrl    String?
  title        String
  description  String?
  imageUrl     String?
  priceText    String?
  category     String?
  affiliateUrl String
  createdAt    DateTime   @default(now())
  draftSets    DraftSet[]
}

model DraftSet {
  id        String   @id @default(cuid())
  productId String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  drafts    Draft[]
}

model Draft {
  id          String   @id @default(cuid())
  draftSetId  String
  title       String
  description String
  cta         String?
  keywords    String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  draftSet    DraftSet @relation(fields: [draftSetId], references: [id], onDelete: Cascade)
}
